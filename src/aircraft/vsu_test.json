{
  "templates": {},
  "devices": [
    { "name": "gnd", "classname": "RefNode", "params": { "value": "0.0" } },
    { "name": "bat_main_1", "classname": "Battery" },
    { "name": "vsu_1", "classname": "RU19A" },
    { "name": "rug_vsu", "classname": "RUG82" },
    { "name": "light_1", "classname": "IndicatorLight" },
    { "name": "t4_sensor", "classname": "LerpNode", "params": { "factor": "0.1" } }
  ],
  "connections": [
    { "from": "gnd.v", "to": "bat_main_1.v_in" },
    { "from": "gnd.v", "to": "light_1.v_out" },
    { "from": "bat_main_1.v_out", "to": "vsu_1.v_start" },
    { "from": "bat_main_1.v_out", "to": "vsu_1.v_out" },
    { "from": "vsu_1.v_out", "to": "light_1.v_in" },
    { "from": "vsu_1.v_out", "to": "rug_vsu.v_gen" },
    { "from": "rug_vsu.k_mod", "to": "vsu_1.k_mod" },
    { "from": "vsu_1.t4_out", "to": "t4_sensor.input" }
  ]
}
