{
  "templates": {},
  "devices": [
    { "name": "gnd", "classname": "RefNode", "params": { "value": "0.0" } },
    { "name": "source", "classname": "RefNode", "params": { "value": "100.0" } },
    { "name": "lerp_1", "classname": "LerpNode", "params": { "factor": "0.05" } },
    { "name": "load", "classname": "Resistor", "params": { "conductance": "1.0" } }
  ],
  "connections": [
    { "from": "gnd.v", "to": "source.v" },
    { "from": "source.v", "to": "lerp_1.input" },
    { "from": "lerp_1.output", "to": "load.v_in" },
    { "from": "load.v_out", "to": "gnd.v" }
  ]
}
