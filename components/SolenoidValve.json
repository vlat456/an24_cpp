{
  "classname": "SolenoidValve",
  "description": "Electrically controlled hydraulic valve",
  "default_ports": {
    "ctrl": {
      "direction": "In",
      "type": "Temperature"
    },
    "flow_in": {
      "direction": "In",
      "type": "I"
    },
    "flow_out": {
      "direction": "Out",
      "type": "Temperature"
    }
  },
  "default_params": {
    "normally_closed": "true"
  },
  "default_domains": [
    "Electrical",
    "Hydraulic"
  ],
  "default_priority": "med",
  "default_critical": false
}
