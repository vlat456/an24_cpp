{
  "classname": "HoldButton",
  "description": "Hold-to-operate button with press/release detection. State output: 1.0V = pressed, 0.0V = released/idle.",
  "default_ports": {
    "control": { "direction": "In" },
    "state": { "direction": "Out" }
  },
  "default_params": {
    "idle": "0.0"
  },
  "default_domains": ["Electrical"],
  "default_priority": "med",
  "default_critical": false,
  "default_content_type": "HoldButton"
}
