{
  "classname": "TempSensor",
  "description": "Temperature sensor with sensitivity",
  "default_ports": {
    "temp_in": {
      "direction": "In",
      "type": "I"
    },
    "temp_out": {
      "direction": "Out",
      "type": "Temperature"
    }
  },
  "default_params": {
    "sensitivity": "1.0"
  },
  "default_domains": [
    "Thermal"
  ],
  "default_priority": "med",
  "default_critical": false
}
