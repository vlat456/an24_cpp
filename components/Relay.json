{
  "classname": "Relay",
  "description": "Electrical relay (on/off switch). When closed, connects v_in to v_out. Uses post_step voltage merging for realistic behavior.",
  "default_ports": {
    "v_in": {
      "direction": "In",
      "type": "V"
    },
    "v_out": {
      "direction": "Out",
      "type": "V"
    },
    "control": {
      "direction": "In",
      "type": "Bool"
    }
  },
  "default_params": {
    "closed": "false"
  },
  "default_domains": [
    "Electrical"
  ],
  "default_priority": "med",
  "default_critical": false
}
