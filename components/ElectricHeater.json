{
  "classname": "ElectricHeater",
  "description": "Electrical heater converting power to heat",
  "default_ports": {
    "power": {
      "direction": "In",
      "type": "Pressure"
    },
    "heat_out": {
      "direction": "Out",
      "type": "Temperature"
    }
  },
  "default_params": {
    "max_power": "1000.0",
    "efficiency": "0.9"
  },
  "default_domains": [
    "Electrical",
    "Thermal"
  ],
  "default_priority": "med",
  "default_critical": false
}
