{
  "classname": "Splitter",
  "description": "1-to-2 signal splitter. One real input port with 2 virtual alias outputs. All ports are type 'Any' for universal compatibility across all domains.",
  "default_ports": {
    "i": {
      "direction": "In",
      "type": "Any"
    },
    "o1": {
      "direction": "Out",
      "alias": "i",
      "type": "Any"
    },
    "o2": {
      "direction": "Out",
      "alias": "i",
      "type": "Any"
    }
  },
  "default_params": {},
  "default_domains": [
    "Electrical",
    "Mechanical",
    "Hydraulic",
    "Thermal"
  ],
  "default_priority": "high",
  "default_critical": false,
  "default_size": {"x": 3, "y": 3}
}
