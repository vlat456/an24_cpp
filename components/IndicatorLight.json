{
  "classname": "IndicatorLight",
  "description": "Aircraft indicator light with brightness output",
  "default_ports": {
    "v_in": {
      "direction": "In",
      "type": "V"
    },
    "v_out": {
      "direction": "Out",
      "type": "V"
    },
    "brightness": {
      "direction": "Out",
      "type": "I"
    }
  },
  "default_params": {
    "max_brightness": "100.0",
    "color": "white"
  },
  "default_domains": [
    "Electrical"
  ],
  "default_priority": "med",
  "default_critical": false,
  "default_content_type": "Text"
}
