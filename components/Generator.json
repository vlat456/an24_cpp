{
  "classname": "Generator",
  "description": "Voltage generator source with internal resistance. Similar to Battery but typically driven by mechanical power (engine/APU).",
  "default_ports": {
    "v_in": { "direction": "In" },
    "v_out": { "direction": "Out" }
  },
  "default_params": {
    "v_nominal": "28.5",
    "internal_r": "0.005"
  },
  "default_domains": ["Electrical"],
  "default_priority": "high",
  "default_critical": false,
  "default_content_type": "Gauge"
}
