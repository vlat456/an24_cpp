{
  "classname": "AZS",
  "description": "Aircraft circuit breaker (Автомат Защиты Сети). Hybrid switch + thermal fuse. Manual toggle via control, auto-trips on overcurrent. Thermal model: T += (I² * r_heat - T * k_cool) * dt. Trips at T > 1.0.",
  "cpp_class": true,
  "ports": {
    "v_in": {
      "direction": "In",
      "type": "V"
    },
    "v_out": {
      "direction": "Out",
      "type": "V"
    },
    "control": {
      "direction": "In",
      "type": "Temperature"
    },
    "state": {
      "direction": "Out",
      "type": "Bool"
    },
    "temp": {
      "direction": "Out",
      "type": "Temperature"
    },
    "tripped": {
      "direction": "Out",
      "type": "Bool"
    }
  },
  "params": {
    "closed": "false",
    "i_nominal": "20.0"
  },
  "domains": ["Electrical", "Thermal"],
  "priority": "med",
  "critical": false,
  "content_type": "Switch"
}
