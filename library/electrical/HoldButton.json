      "direction": "In",
      "type": "V"
    },
    "v_out": {
      "direction": "Out",
      "type": "V"
    },
    "control": {
      "direction": "In",
      "type": "Temperature"
    },
    "state": {
      "direction": "Out",
      "type": "Bool"
    }
  },
  "params": {
    "idle": "0.0"
  },
  "domains": [
    "Electrical"
  ],
  "priority": "med",
  "critical": false,
  "content_type": "HoldButton"
}
