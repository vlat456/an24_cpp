{
  "description": "Voltage pass-through with indicator lamp for debug",
  "devices": [
    {
      "name": "vin",
      "classname": "BlueprintInput",
      "params": {
        "exposed_type": "V",
        "exposed_direction": "In"
      }
    },
    {
      "name": "lamp",
      "classname": "IndicatorLight",
      "params": {
        "max_brightness": "100.0",
        "color": "red"
      }
    },
    {
      "name": "vout",
      "classname": "BlueprintOutput",
      "params": {
        "exposed_type": "V",
        "exposed_direction": "Out"
      }
    }
  ],
  "connections": [
    {
      "from": "vin.port",
      "to": "lamp.v_in"
    },
    {
      "from": "lamp.v_out",
      "to": "vout.port"
    }
  ]
}
